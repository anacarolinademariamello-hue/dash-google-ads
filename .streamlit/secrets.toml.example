# Copie este arquivo para .streamlit/secrets.toml e preencha os valores reais.

# Supabase — mesmo projeto dos outros apps
supabase_url        = "https://<project-ref>.supabase.co"
supabase_service_key = "<service_role key>"

# Anthropic — geração de análise estratégica com Claude
ANTHROPIC_API_KEY = "sk-ant-..."

# Gmail — envio de e-mail de lembrete semanal
GMAIL_USER         = "seu-email@gmail.com"
GMAIL_APP_PASSWORD = "xxxx xxxx xxxx xxxx"
EMAIL_TO           = "destinatario@gmail.com"
